    <sys:String x:Key="SearchFunction">Tìm kiếm chức năng</sys:String>
    <sys:String x:Key="SearchFunctionToolTip">Ctrl+F để tìm kiếm chức năng</sys:String>
    <sys:String x:Key="Function">Chức năng</sys:String>
    <sys:String x:Key="Appearance">Giao diện</sys:String>
    <sys:String x:Key="AutoTranslateEnabled">Bật dịch tự động</sys:String>
    <sys:String x:Key="AutoTranslateDisabled">Tắt dịch tự động</sys:String>
    <sys:String x:Key="General_AutoStartup">Khởi động cùng hệ thống</sys:String>
    <sys:String x:Key="General_AutoStartupDescription">Tự động khởi chạy phần mềm khi máy tính khởi động.</sys:String>
    <sys:String x:Key="General_StartMode">Chế độ khởi động</sys:String>
    <sys:String x:Key="General_StartModeDescription">"SkipUACAdmin" sẽ tạo tác vụ theo lịch để bỏ qua cửa sổ UAC.</sys:String>
    <sys:String x:Key="General_HideOnStartup">Ẩn cửa sổ khi khởi động hệ thống</sys:String>
    <sys:String x:Key="General_HideOnStartupDescription">Cửa sổ tìm kiếm sẽ ẩn xuống khay sau khi STranslate khởi động.</sys:String>
    <sys:String x:Key="General_HideWhenDeactivated">Tự động ẩn cửa sổ khi mất tiêu điểm</sys:String>
    <sys:String x:Key="General_WindowPosition">Vị trí cửa sổ chính</sys:String>
    <sys:String x:Key="General_WindowAlign">Vị trí cửa sổ chính trên màn hình</sys:String>
    <sys:String x:Key="General_MainWindowMaxHeightRatio">Chiều cao tối đa cửa sổ chính (Tỉ lệ màn hình)</sys:String>
    <sys:String x:Key="General_MainWindowMaxHeightRatioDescription">Điều chỉnh chiều cao tối đa của cửa sổ chính theo tỉ lệ vùng làm việc của màn hình hiện tại (60%-100%).</sys:String>
    <sys:String x:Key="General_DisableGlobalHotkeys">Tắt phím tắt toàn cục</sys:String>
    <sys:String x:Key="General_IgnoreHotkeysOnFullscreen">Bỏ qua phím tắt khi ở chế độ toàn màn hình</sys:String>
    <sys:String x:Key="General_IgnoreHotkeysOnFullscreenDescription">Ưu tiên thấp hơn "Tắt phím tắt toàn cục", thường dùng khi chơi game.</sys:String>
    <sys:String x:Key="General_LanguageDetector">Trình phát hiện ngôn ngữ</sys:String>
    <sys:String x:Key="General_LocalDetector">Tỉ lệ ký tự Trung-Anh khi phát hiện cục bộ</sys:String>
    <sys:String x:Key="General_LocalDetectorDescription">Chỉ áp dụng cho "Phát hiện cục bộ" với tỉ lệ ký tự tiếng Anh trên tổng số ký tự trong văn bản Trung-Anh.</sys:String>
    <sys:String x:Key="General_DefaultSourceLanguage">Ngôn ngữ nguồn mặc định</sys:String>
    <sys:String x:Key="General_DefaultSourceLanguageDescription">Sử dụng ngôn ngữ này khi phát hiện tự động thất bại.</sys:String>
    <sys:String x:Key="General_FirstLanguage">Ngôn ngữ thứ nhất</sys:String>
    <sys:String x:Key="General_FirstLanguageDescription">Khi ngôn ngữ đích là Tự động và ngôn ngữ nguồn là một ngôn ngữ khác (kể cả ngôn ngữ thứ hai), ngôn ngữ đích sẽ dùng ngôn ngữ thứ nhất.</sys:String>
    <sys:String x:Key="General_SecondLanguage">Ngôn ngữ thứ hai</sys:String>
    <sys:String x:Key="General_SecondLanguageDescription">Khi ngôn ngữ đích là Tự động và ngôn ngữ nguồn là ngôn ngữ thứ nhất, ngôn ngữ đích sẽ dùng ngôn ngữ thứ hai.</sys:String>
    <sys:String x:Key="General_HttpTimeout">Thời gian chờ</sys:String>
    <sys:String x:Key="General_HttpTimeoutDescription">Thời gian chờ tối đa của yêu cầu mạng (giây).</sys:String>
    <sys:String x:Key="General_UseClipboardOutput">Dùng clipboard để xuất văn bản</sys:String>
    <sys:String x:Key="General_UseClipboardOutputDescription">Khi bật, đầu ra dùng clipboard Ctrl+V; khi tắt, dùng mô phỏng nhập bàn phím (mặc định).</sys:String>
    <sys:String x:Key="General_TranslateOnPaste">Dịch khi dán</sys:String>
    <sys:String x:Key="General_TranslateOnPasteDescription">Thực hiện dịch ngay khi dán văn bản vào ô nhập liệu.</sys:String>
    <sys:String x:Key="General_AutoTranslate">Dịch tự động</sys:String>
    <sys:String x:Key="General_AutoTranslateDescription">Tự động dịch sau khoảng thời gian chờ khi nhập nội dung.</sys:String>
    <sys:String x:Key="General_InstantTranslate">Dịch tức thì</sys:String>
    <sys:String x:Key="General_InstantTranslateDescription">Dịch ngay khi xảy ra các hành động sau.</sys:String>
    <sys:String x:Key="General_AutoTranslateButtonVisible">Hiển thị nút dịch tự động trên giao diện chính</sys:String>
    <sys:String x:Key="General_AutoTranslateOnPromptChanged">Tự động dịch khi đổi Prompt</sys:String>
    <sys:String x:Key="General_AutoTranslateOnPromptChangedDescription">Dịch lại ngay sau khi chuyển prompt cho dịch vụ dịch AI.</sys:String>
    <sys:String x:Key="General_AutoTranslateDelay">Độ trễ dịch tự động</sys:String>
    <sys:String x:Key="General_AutoTranslateDelayDescription">Thời gian chờ sau khi nhập nội dung, đơn vị: mili giây.</sys:String>
    <sys:String x:Key="General_LineBreakHandleType">Xử lý ngắt dòng</sys:String>
    <sys:String x:Key="General_LineBreakHandleTypeDescription" xml:space="preserve">Bao gồm xử lý ngắt dòng cho chọn từ, dịch ảnh chụp, clipboard và OCR im lặng.&#10;"Xoá ngắt dòng thừa" chủ yếu dành cho trích xuất văn bản PDF, loại bỏ ngắt dòng và ngắt câu thừa, nhưng có thể ảnh hưởng tới văn bản không phải PDF.</sys:String>
    <sys:String x:Key="General_SelectedTextFetchTimeout">Thời gian chờ lấy văn bản</sys:String>
    <sys:String x:Key="General_SelectedTextFetchTimeoutDescription">Thời gian chờ kiểm tra clipboard mới sau khi mô phỏng sao chép, tính bằng mili giây. Trả về ngay khi văn bản được cập nhật; tăng giá trị này cho ứng dụng PDF cập nhật chậm.</sys:String>
    <sys:String x:Key="General_SelectedTextFetchTimeoutPlaceholder">500</sys:String>
    <sys:String x:Key="General_CrosswordFetchFailedFallbackTarget">Phương án dự phòng khi chọn từ thất bại</sys:String>
    <sys:String x:Key="General_CrosswordFetchFailedFallbackTargetDescription">Khi không lấy được văn bản đã chọn, chọn chuyển sang dịch nhập liệu hoặc chỉ hiện cửa sổ chính.</sys:String>
    <sys:String x:Key="General_ImageQuality">Chất lượng hình ảnh</sys:String>
    <sys:String x:Key="General_ImageQualityDescription">Điều chỉnh chất lượng khi xử lý hình ảnh. Dịch vụ OCR trực tuyến có thể giới hạn kích thước ảnh.</sys:String>
    <sys:String x:Key="General_DoubleClickTrayFunction">Chức năng nháy đúp khay</sys:String>
    <sys:String x:Key="General_DoubleClickTrayFunctionDescription">Chọn bất kỳ hành động nào ngoài "Không có" sẽ tắt chức năng nháy đơn để bật/tắt cửa sổ chính.</sys:String>
    <sys:String x:Key="General_Language">Ngôn ngữ</sys:String>
    <sys:String x:Key="General_ScreenshotTranslate">Dịch ảnh chụp màn hình</sys:String>
    <sys:String x:Key="General_ImageTranslate">Dịch hình ảnh</sys:String>
    <sys:String x:Key="General_ShowScreenshotTranslate">Hiển thị dịch ảnh chụp màn hình</sys:String>
    <sys:String x:Key="General_ShowScreenshotTranslateDescription">Hiển thị nút "Dịch ảnh chụp màn hình" trên giao diện chính. Chụp ảnh, nhận dạng văn bản, đưa vào ô nhập rồi dịch</sys:String>
    <sys:String x:Key="General_ShowImageTranslate">Hiển thị dịch hình ảnh</sys:String>
    <sys:String x:Key="General_ShowImageTranslateDescription">Hiển thị nút "Dịch hình ảnh" trên giao diện chính. Chụp ảnh và dịch trực tiếp trên hình</sys:String>
    <sys:String x:Key="General_ShowScreenshotAuxiliaryLines">Đường phụ trợ khi chụp ảnh</sys:String>
    <sys:String x:Key="General_ShowScreenshotAuxiliaryLinesDescription">Có hiển thị đường phụ trợ khi chụp ảnh để chọn vùng chính xác hơn không.</sys:String>
    <sys:String x:Key="General_HideNotifyIcon">Ẩn biểu tượng thông báo</sys:String>
    <sys:String x:Key="General_ShowScreenshotItemInNotifyIconMenu">Hiển thị Dịch ảnh chụp trong menu khay</sys:String>
    <sys:String x:Key="General_ShowImageTranslateItemInNotifyIconMenu">Hiển thị Dịch hình ảnh trong menu khay</sys:String>
    <sys:String x:Key="General_ShowOcrItemInNotifyIconMenu">Hiển thị Nhận dạng văn bản trong menu khay</sys:String>
    <sys:String x:Key="General_ShowQrCodeItemInNotifyIconMenu">Hiển thị Mã QR trong menu khay</sys:String>
    <sys:String x:Key="General_ColorTheme">Bảng màu</sys:String>
    <sys:String x:Key="General_ColorThemeDescription">Chọn bảng màu hiển thị.</sys:String>
    <sys:String x:Key="General_ColorThemeButtonVisible">Hiển thị nút bảng màu trên giao diện chính</sys:String>
    <sys:String x:Key="General_HideInputBox">Ẩn ô nhập liệu</sys:String>
    <sys:String x:Key="General_HideInputBoxDescription">Có ẩn ô nhập liệu hay không.</sys:String>
    <sys:String x:Key="General_HideInputBoxButtonVisible">Hiển thị nút ẩn ô nhập liệu trên giao diện chính</sys:String>
    <sys:String x:Key="General_HideLanguageControl">Ẩn điều khiển chọn ngôn ngữ</sys:String>
    <sys:String x:Key="General_HideLanguageControlDescription">Có ẩn điều khiển chọn ngôn ngữ khi ẩn ô nhập liệu hay không.</sys:String>
    <sys:String x:Key="General_ShowMouseHook">Hiển thị mouse hook</sys:String>
    <sys:String x:Key="General_ShowMouseHookDescription">Có hiển thị biểu tượng bật/tắt nhanh chọn từ bằng chuột trên giao diện chính hay không.</sys:String>
    <sys:String x:Key="General_ShowHistoryNavigation">Hiển thị điều hướng lịch sử</sys:String>
    <sys:String x:Key="General_ShowHistoryNavigationDescription">Có hiển thị biểu tượng tiến/lùi lịch sử dịch trên giao diện chính hay không.</sys:String>
    <sys:String x:Key="General_ShowOcrButton">Hiển thị nút OCR</sys:String>
    <sys:String x:Key="General_ShowOcrButtonDescription">Hiển thị nút OCR trên thanh tiêu đề của giao diện chính.</sys:String>
    <sys:String x:Key="General_ShowClipboardMonitor">Hiển thị nút giám sát clipboard</sys:String>
    <sys:String x:Key="General_ShowClipboardMonitorDescription">Hiển thị nút bật/tắt giám sát clipboard trên thanh tiêu đề của giao diện chính.</sys:String>
    <sys:String x:Key="General_MainHeaderConfig">Bố cục nút trên thanh tiêu đề chính</sys:String>
    <sys:String x:Key="General_MainHeaderConfigDescription">Hàng trên là Xem trước, hàng dưới là Hồ chứa hành động. Kéo từ Hồ chứa lên Xem trước để hiển thị, kéo ngược lại để ẩn, kéo trong Xem trước để sắp xếp.</sys:String>
    <sys:String x:Key="General_MainHeaderPreview">Xem trước (Thanh tiêu đề chính)</sys:String>
    <sys:String x:Key="General_MainHeaderPool">Hồ chứa hành động (Đã ẩn)</sys:String>
    <sys:String x:Key="General_MainHeaderShowAll">Hiện tất cả</sys:String>
    <sys:String x:Key="General_MainHeaderHideAll">Ẩn tất cả</sys:String>
    <sys:String x:Key="General_FontSize">Cỡ chữ</sys:String>
    <sys:String x:Key="General_FontSizeDescription">Điều chỉnh cỡ chữ cho mọi thành phần trừ menu chuột phải</sys:String>
    <sys:String x:Key="General_OutputShowingControl">Điều khiển hiển thị đầu ra</sys:String>
    <sys:String x:Key="General_ShowPascalCase">Hiển thị nút sao chép PascalCase</sys:String>
    <sys:String x:Key="General_ShowCamelCase">Hiển thị nút sao chép camelCase</sys:String>
    <sys:String x:Key="General_ShowSnakeCase">Hiển thị nút sao chép snake_case</sys:String>
    <sys:String x:Key="General_ShowInsert">Hiển thị nút chèn văn bản</sys:String>
    <sys:String x:Key="General_ShowBackTranslation">Hiển thị nút dịch ngược</sys:String>
    <sys:String x:Key="General_ShowPrompt">Hiển thị Prompt</sys:String>
    <sys:String x:Key="General_ShowPromptDescription">Có hiển thị nút chuyển prompt cho dịch vụ dịch AI trên giao diện chính hay không</sys:String>
    <sys:String x:Key="General_FontFamily">Kiểu chữ</sys:String>
    <sys:String x:Key="General_HistoryCount">Số lượng lịch sử</sys:String>
    <sys:String x:Key="General_CopyAfterTranslation">Sao chép sau khi dịch</sys:String>
    <sys:String x:Key="General_CopyAfterTranslationDescription">Chỉ áp dụng cho dịch vụ ở chế độ "Tự động"</sys:String>
    <sys:String x:Key="General_CopyAfterTranslationNotAutomatic">Sao chép sau khi dịch cho dịch vụ không phải "Tự động"</sys:String>
    <sys:String x:Key="General_CopyAfterOcr">Sao chép sau khi OCR</sys:String>
    <sys:String x:Key="General_CopyAfterOcrDescription">Áp dụng cho mọi tình huống nhận dạng văn bản, tự động sao chép kết quả sau khi OCR.</sys:String>
    <sys:String x:Key="General_PluginMarketCdnSource">Nguồn CDN cửa hàng tiện ích</sys:String>
    <sys:String x:Key="General_PluginMarketCdnSourceDescription">Chọn dịch vụ tăng tốc CDN cho dữ liệu cửa hàng tiện ích (GitHub trực tiếp không có độ trễ bộ đệm)</sys:String>
    <sys:String x:Key="General_CustomCdnUrl">URL CDN tuỳ chỉnh</sys:String>
    <sys:String x:Key="General_CustomCdnUrlDescription">Nhập mẫu URL CDN tuỳ chỉnh, dùng {author}, {repo}, {branch}, {path} làm chỗ giữ chỗ</sys:String>

    <!--  // PluginMarketCdnSourceType //  -->
    <sys:String x:Key="PluginMarketCdnSourceTypeJsDelivr">jsDelivr CDN (Khuyến nghị)</sys:String>
    <sys:String x:Key="PluginMarketCdnSourceTypeGitHubRaw">GitHub Trực tiếp</sys:String>
    <sys:String x:Key="PluginMarketCdnSourceTypeCustom">Tuỳ chỉnh</sys:String>

