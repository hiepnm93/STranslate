    <sys:String x:Key="PluginDownloadProxyTypeGhProxyNet">ghproxy.net</sys:String>
    <sys:String x:Key="PluginDownloadProxyTypeCustom">Tuỳ chỉnh</sys:String>

    <!--  // Hotkey Page //  -->
    <sys:String x:Key="GlobalHotkeys">Phím tắt toàn cục</sys:String>
    <sys:String x:Key="SoftwareHotkeys">Phím tắt phần mềm</sys:String>
    <sys:String x:Key="Hotkey_OpenSTranslate">Mở STranslate</sys:String>
    <sys:String x:Key="Hotkey_OpenSTranslateDescription">Phím tắt để hiện/ẩn giao diện chính của STranslate.</sys:String>
    <sys:String x:Key="Hotkey_InputTranslate">Dịch nhập liệu</sys:String>
    <sys:String x:Key="Hotkey_InputTranslateDescription">Phím tắt để mở STranslate và xoá nội dung phục vụ dịch nhập liệu.</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslate">Dịch chọn từ</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslateDescription">Phím tắt để dịch văn bản đã chọn bằng chuột.</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslateIsUseCtrlSameC">Sử dụng Ctrl+C+C cho dịch chọn từ?</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslateTraditional">Phím tắt truyền thống</sys:String>
    <sys:String x:Key="Hotkey_CrosswordTranslateByCtrlSameCDescription">Sau khi chọn văn bản bằng chuột, nhấn nhanh Ctrl+C+C để dịch.</sys:String>
    <sys:String x:Key="CrosswordTranslateFetchFailed">Không lấy được văn bản đã chọn, chuyển sang dịch nhập liệu.</sys:String>
    <sys:String x:Key="CrosswordTranslateFetchFailedShowWindow">Không lấy được văn bản đã chọn, chuyển sang hiện cửa sổ chính.</sys:String>
    <sys:String x:Key="Hotkey_MouseHookTranslate">Dịch theo chuột</sys:String>
    <sys:String x:Key="Hotkey_MouseHookTranslateDescription">Phím tắt bật/tắt lắng nghe chọn văn bản bằng chuột để kích hoạt dịch.</sys:String>
    <sys:String x:Key="Hotkey_ReplaceTranslate">Dịch thay thế</sys:String>
    <sys:String x:Key="Hotkey_ReplaceTranslateDescription">Phím tắt để dịch văn bản đã chọn và thay thế văn bản gốc.</sys:String>
    <sys:String x:Key="Hotkey_ScreenshotTranslate">Dịch ảnh chụp màn hình</sys:String>
    <sys:String x:Key="Hotkey_ScreenshotTranslateDescription">Phím tắt để chụp một vùng đã chọn, nhận dạng văn bản và dịch.</sys:String>
    <sys:String x:Key="Hotkey_ImageTranslate">Dịch hình ảnh</sys:String>
    <sys:String x:Key="Hotkey_ImageTranslateDescription">Phím tắt để chụp ảnh, chọn vùng, nhận dạng văn bản và dịch trực tiếp trên ảnh.</sys:String>
    <sys:String x:Key="Hotkey_SilentOcr">OCR im lặng</sys:String>
    <sys:String x:Key="Hotkey_SilentOcrDescription">Phím tắt để chụp một vùng đã chọn, nhận dạng văn bản và đặt vào clipboard.</sys:String>
    <sys:String x:Key="Hotkey_SilentTts">TTS im lặng</sys:String>
    <sys:String x:Key="Hotkey_SilentTtsDescription">Phím tắt để tổng hợp giọng nói cho văn bản tiếng Trung được chọn bằng chuột.</sys:String>
    <sys:String x:Key="Hotkey_Ocr">OCR</sys:String>
    <sys:String x:Key="Hotkey_OcrDescription">Phím tắt để mở cửa sổ OCR và nhận dạng văn bản.</sys:String>
    <sys:String x:Key="Hotkey_ClipboardMonitor">Dịch giám sát clipboard</sys:String>
    <sys:String x:Key="Hotkey_ClipboardMonitorDescription">Bật/tắt giám sát clipboard. Khi bật, mọi thay đổi clipboard sẽ tự động dịch.</sys:String>
    <sys:String x:Key="ClipboardMonitorStarted">Đã bắt đầu giám sát clipboard</sys:String>
    <sys:String x:Key="ClipboardMonitorStopped">Đã dừng giám sát clipboard</sys:String>
